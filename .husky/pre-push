if git diff origin/$(git rev-parse --abbrev-ref HEAD)..HEAD --name-only 2>/dev/null | grep -q "^br-app/"; then
  cd br-app && npx jest --passWithNoTests
  cd ..
fi

if git diff origin/$(git rev-parse --abbrev-ref HEAD)..HEAD --name-only 2>/dev/null | grep -q "^br-api/"; then
  cd br-api && go test ./...
fi
